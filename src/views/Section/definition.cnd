[jahiacom:section] > jnt:content, jahiacommix:cta, jahiacommix:container, mix:title orderable
 - subtitle (string, richtext) i18n
 - columns (string, choicelist[resourceBundle]) = '100' < '100', '50-50','irregular-100-50-50', 'irregular-50-50-100', 'irregular-100-33-33-33', 'irregular-33-33-33-100', '67-33', '33-67', 'irregular-67-33', '33-33-33', '25-25-25-25', 'irregular-3-2'
 - width (string, choicelist[resourceBundle]) = '100' < '100', '75', '50'
 - gap (string, choicelist[resourceBundle]) = '1' < '0', '1', '2'
 - cut (string, choicelist[resourceBundle]) = 'before' < 'before', 'after', 'both'
 + * (jahiacommix:component)
